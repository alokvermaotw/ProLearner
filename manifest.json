{
  "manifest_version": 3,
  "name": "ProLearner",
  "version": "1.0.0",
  "description": "An extension for Chrome/Chromium to make page-based learning and notes sync easy using LLMs.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Toggle ProLearner Sidebar"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "panel.js", "panel.css", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
